# Backend Environment Variables Template
# Copy to .env (development) or use with Vercel environment variables for production

# ─── Supabase Cloud ──────────────────────────────────────
# For development: Use values from 'pnpm supabase start'
# For production: Use values from Supabase Cloud Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE=your-supabase-service-role-key-here

# ─── Server Configuration ────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── CORS Configuration ──────────────────────────────────
# Development: Allow localhost frontend
# Production: Set to your deployed frontend URL, e.g., https://isy-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173

# Note: Do not commit .env file to git (it's in .gitignore)
# Use Vercel Environment Variables for production deployment
